#
# AGENTIC.a2ml — AI agent constraints and capabilities
# Defines what AI agents can and cannot do in this repository.

[metadata]
version = "0.1.0"
last-updated = "2026-07-21"

[agent-permissions]
can-edit-source = true
can-edit-tests = true
can-edit-docs = true
can-edit-config = true
can-create-files = true

[agent-constraints]
# What AI agents MUST NOT do in F19 Stealth Glider:
#
# - Never violate B3/S23. No special-cased cells, no scripted entities, no
#   hazard that is not a real Life pattern. The automaton being genuine is the
#   entire premise (D-01).
# - Never edit src/level.mjs to make a failing verification script pass. The
#   level is frozen geometry (D-02). If a route fails, redesign the crossing or
#   record the negative result.
# - Never weaken the contact rule (mission.mjs `nearWorld(M, cells, 2)`) to open
#   a route. Relaxing it to cell-overlap makes the stream learnable by feel,
#   which converts the substrate into scenery and fails v0's premise. This is
#   the project's standing falsifier, and it is a design failure, not a fix.
# - Never re-derive the stream no-go lemma. It is CLOSED: 0/30 clean crossings,
#   cause is geometry (15-unit spacing vs ~17-unit exclusion diameter), not
#   phase. See verify8.mjs and VERIFICATION.md claim #4.
# - Never relax `stamp` to clip or wrap on out-of-bounds. It throws on purpose;
#   silent wrapping previously manufactured a phantom clean landing lane (D-06).
#   Sweeps needing negative lanes must enlarge the grid and co-shift the whole
#   configuration — Life is translation-invariant away from borders, so the
#   measured RELATIVE lane is preserved.
# - Never commit a stale f19-stealth-glider.html. It must always equal a fresh
#   `just build`; CI asserts byte-identity.
# - Never delete the exploratory scripts (verify4,5,6,7,10). Their "no viable
#   candidate" output is a recorded negative result, not a broken test.
# - Never change the licence. All code is AGPL-3.0-or-later; the .a2ml metadata
#   set is MPL-2.0. Staying copyleft is deliberate.
# - Never commit secrets or credentials.
# - Never place state/metadata in the repository root — it belongs under
#   .machine_readable/ (the root carries only 0-AI-MANIFEST.a2ml + k9iser.toml).
# - Never add a runtime dependency without an explicit decision record. Zero
#   dependencies is a design property, not an accident (D-08).
# - Never claim a verification result without running the script. "Installed and
#   run", never asserted.

[commit-policy]
require-signoff = true               # git commit -s
signoff-standard = "DCO-1.1"

[maintenance-integrity]
fail-closed = true
require-evidence-per-step = true
allow-silent-skip = false
require-rerun-after-fix = true
release-claim-requires-hard-pass = true
ledger-claims-require-named-script = true   # every VERIFICATION.md row cites a runnable script

[automation-hooks]
# on-enter:  Read 0-AI-MANIFEST.a2ml, then 6a2/STATE.a2ml, then VERIFICATION.md.
# on-change: If src/ changed, run `just test` (ledger + rebuild + reproducibility diff).
#            If a claim changed, update VERIFICATION.md in the same commit.
#            If .machine_readable/ changed, run `just contracts`.
# on-commit: Sign off (git commit -s). Commit email must be the GitHub noreply
#            address — pushing with a private email is blocked by GH007.
